{
  "rewrites": [
    {
      "source": "/share/cotizacion/:id",
      "destination": "/api/share/cotizacion/:id?share=1"
    },
    {
      "source": "/cotizacion/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": {
            "re": ".*(facebookexternalhit|FacebookExternalHit|Facebot|facebot|WhatsApp|whatsapp|Twitterbot|twitterbot|Xbot|xbot|LinkedInBot|linkedinbot|Slackbot|slackbot|Discordbot|discordbot|TelegramBot|telegrambot|SkypeUriPreview|skypeuripreview|meta-externalagent).*"
          }
        }
      ],
      "destination": "/api/share/cotizacion/:id?share=0"
    },

    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
